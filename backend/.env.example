LLM_PROVIDER=none
# LLM_PROVIDER=auto
# LLM_PROVIDER=openai,deepseek,doubao,ollama
# Optional: override SQLite storage directory. Must stay inside backend/.
# FULLMIND_STORAGE_DIR=storage
# Optional: override SQLite file name inside the storage directory.
FULLMIND_DB_FILENAME=fullmind_app.db
# Optional: use WAL/DELETE if your local folder allows SQLite journal files.
FULLMIND_SQLITE_JOURNAL_MODE=OFF
# Optional model discovery. When true, FullMind calls provider /models endpoints
# and adds newly discovered models as unverified candidates.
FULLMIND_LLM_DISCOVER=false

# OpenAI-compatible text providers.
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODELS=gpt-4o-mini

# DeepSeek.
# DEEPSEEK_API_KEY=
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# DEEPSEEK_MODELS=deepseek-chat,deepseek-reasoner

# Doubao / Volcano Ark. Text models can use the OpenAI-compatible endpoint.
# Image models are currently routed but image invocation is a separate next step.
# DOUBAO_API_KEY=
# DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# DOUBAO_MODELS=

# Ollama OpenAI-compatible endpoint.
# OLLAMA_BASE_URL=http://127.0.0.1:11434/v1
# OLLAMA_MODELS=qwen2.5

# Optional. Defaults to backend/storage/fullmind.db
# DATABASE_URL=sqlite:///./storage/fullmind.db

# Recommended dev port: 8010.
# Port 8000 is often occupied by local printer services such as C-Lodop.
